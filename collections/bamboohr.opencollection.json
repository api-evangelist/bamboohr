      "info": {
        "name": "Directory",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get the employee directory",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.bamboohr.com/api/gateway.php/{companyDomain}/v1/employees/directory",
            "auth": {
              "type": "basic",
              "username": "{{username}}",
              "password": "{{password}}"
            }
          },
          "docs": "Get the employee directory"
        }
      ]
    },
